rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Admin check via hardcoded email whitelist (fast, no extra DB read)
    function isAdminByEmail() {
      return isAuthenticated() && (
        request.auth.token.email == 'jayant.kgp81@gmail.com' ||
        request.auth.token.email == 'jayantkumar1985kh@gmail.com'
      );
    }

    // Role-Based Access Control (DB role check for teachers/admins with role field)
    function isAdmin() {
      return isAdminByEmail() || (
        isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'teacher', 'super_admin']
      );
    }

    // --- 1. User Data (Strict Ownership) ---
    match /users/{userId} {
      // Users can modify their own data. Admins can read and write all.
      allow write: if isOwner(userId) || isAdminByEmail();
      // Public Read (Authenticated) required for Leaderboards/Search logic
      allow read: if isAuthenticated();
      
      // --- Social Feature Subcollections (SECURED) ---
      
      // 1. Friend Requests: Auth users can write (send), Owner can read (receive)
      match /friend_requests/{requestId} {
        allow read: if isOwner(userId);
        allow write: if isAuthenticated();
      }

      // 2. Friends: Auth users can write (accept/add), Owner can read
      match /friends/{friendId} {
        allow read: if isOwner(userId);
        allow write: if isAuthenticated();
      }

      // 3. Game Invites: Auth users can write (invite), Owner can read
      match /game_invites/{inviteId} {
        allow read: if isOwner(userId);
        allow write: if isAuthenticated();
      }

      // 4. Sent Game Invites: Auth users can write (respond to invite), Owner can read
      match /sent_game_invites/{inviteId} {
        allow read: if isOwner(userId);
        allow write: if isAuthenticated();
      }

      // 5. Syllabus Tracker
      match /syllabus_tracker/{docId} {
        allow read, write: if isOwner(userId);
      }

      // 6. Quiz Results
      match /quiz_results/{docId} {
        allow read, write: if isOwner(userId);
      }

      // 7. Completed Videos
      match /completed_videos/{docId} {
        allow read, write: if isOwner(userId);
      }

      // 8. Daily Challenges
      match /daily_challenges/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Mind Games
    match /mind_games/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- 4. Admin & Public Content (Tuitions & Notifications) ---
    match /tuitions/{tuitionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      // Allow users to mark as read (append to readBy array)
      allow update: if isAuthenticated() && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']);
    }

    // --- 2. Admin Only Content ---
    match /questions/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /notes/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /chapters/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /batches/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /metadata/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /live_quizzes/{quizId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantsCount']));
      
      match /reminders/{userId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    match /video_resources/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Teachers Collection (Super Admin Panel) ---
    // Allow admin emails to fully manage teachers
    match /teachers/{email} {
      allow read, write: if isAdminByEmail();
    }

    // --- 3. Interactive Features ---
    match /rooms/{document=**} { 
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); 
    }
    
    match /results/{document=**} {
      allow read, write: if isAuthenticated();
    }

    match /live_quiz_results/{document=**} {
      allow read, write: if isAuthenticated();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
